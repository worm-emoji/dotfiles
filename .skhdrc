# Toggle fullscreen
alt - return : yabai -m window --toggle zoom-fullscreen

# Toggle float/tile
alt - t : yabai -m window --toggle float

# Toggle bsp/stack layout
alt - f : yabai -m space --layout stack 
alt - b : yabai -m space --layout bsp

# Equalize tiling sizes
alt - 0x18 : yabai -m space --balance

# Focus neighbors
ctrl + alt - h : yabai -m window --focus west
ctrl + alt - j : yabai -m window --focus south
ctrl + alt - k : yabai -m window --focus north
ctrl + alt - l : yabai -m window --focus east

# Space navigation
ctrl + alt - left  : yabai -m space --focus prev || yabai -m space --focus last
ctrl + alt - right : yabai -m space --focus next || yabai -m space --focus first

# Jump to space
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9

# Move window to prev/next space
ctrl + alt + shift - left  : yabai -m window --space prev; yabai -m space --focus prev
ctrl + alt + shift - right : yabai -m window --space next; yabai -m space --focus next

# Restart yabai
alt - 0 : launchctl kickstart -k "gui/${UID}/homebrew.mxcl.yabai"

# Obsidian centered popover toggle (press again to dismiss)
alt - o : "$HOME/r/dotfiles/.yabai-obsidian-popover.sh" toggle

.blacklist [
    "simulator"
]
